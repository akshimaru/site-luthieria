<!-- Hero Section -->
<section class="hero" style="background-image: url('<%= siteData.hero.background_image %>');">
    <div class="hero-content">
        <div class="container">
            <h1><%= siteData.hero.title %></h1>
            <p><%= siteData.hero.subtitle %></p>
            <div class="hero-buttons">
                <a href="/servicos" class="btn-primary">
                    Nossos Serviços
                </a>
                <a href="/contato" class="btn-secondary">
                    Solicitar Orçamento
                </a>
            </div>
        </div>
    </div>
    
    <!-- Scroll Indicator -->
    <div class="scroll-indicator">
        <span class="animate-bounce">⬇</span>
    </div>
</section>

<!-- Services Preview -->
<section class="section-padding bg-white">
    <div class="container">
        <div class="text-center mb-16">
            <h2 class="section-title">Nossos Serviços</h2>
            <p class="section-subtitle">
                Oferecemos uma gama completa de serviços especializados para manter seu instrumento sempre em perfeitas condições
            </p>
        </div>
        
        <div class="services-grid">
            <% siteData.services.slice(0, 3).forEach(function(service) { %>
            <div class="service-card">
                <div class="service-icon">
                    <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                </div>
                <h3 class="service-title"><%= service.name %></h3>
                <p class="service-description"><%= service.description %></p>
                <span class="service-price"><%= service.price %></span>
            </div>
            <% }); %>
        </div>
        
        <div class="text-center mt-12">
            <a href="/servicos" class="btn-primary">
                Ver Todos os Serviços
            </a>
        </div>
    </div>
</section>

