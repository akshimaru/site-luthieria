<!-- Gallery Preview -->
<section class="section-padding bg-white">
    <div class="container">
        <div class="text-center mb-16">
            <h2 class="section-title">Nossos Trabalhos</h2>
            <p class="section-subtitle">
                Veja alguns exemplos dos nossos trabalhos realizados. Cada instrumento recebe cuidado especial e atenção aos detalhes.
            </p>
        </div>
        
        <div class="gallery-grid">
            <div class="gallery-item">
                <div class="gallery-image">
                    <img src="https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Restauração Guitarra Vintage" class="gallery-img">
                    <div class="gallery-overlay">
                        <div class="gallery-content">
                            <h3 class="gallery-title">Restauração Completa</h3>
                            <p class="gallery-subtitle">Guitarra Vintage dos anos 70</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="gallery-item">
                <div class="gallery-image">
                    <img src="https://images.unsplash.com/photo-1459305272254-33ac53d2d350?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Setup Baixo Fender" class="gallery-img">
                    <div class="gallery-overlay">
                        <div class="gallery-content">
                            <h3 class="gallery-title">Setup Profissional</h3>
                            <p class="gallery-subtitle">Baixo Fender 4 Cordas</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="gallery-item">
                <div class="gallery-image">
                    <img src="https://images.unsplash.com/photo-1564186763535-ebb21ef5277f?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Reparo Violão Clássico" class="gallery-img">
                    <div class="gallery-overlay">
