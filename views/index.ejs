            </div>
        </div>
        
        <div class="text-center mt-12">
            <a href="/galeria" class="btn-primary">
                Ver Galeria Completa
            </a>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section">
    <div class="container text-center">
        <h2 class="cta-title">
            Seu Instrumento Merece o Melhor Cuidado
        </h2>
        <p class="cta-subtitle">
            Entre em contato conosco e solicite um orçamento personalizado. 
            Nossos especialistas estão prontos para cuidar do seu instrumento.
        </p>
        <div class="cta-buttons">
            <a href="/contato" class="btn-primary">
                Solicitar Orçamento
            </a>
            <a href="tel:+5511999999999" class="btn-outline">
                Ligar Agora
            </a>
        </div>
    </div>
</section>
