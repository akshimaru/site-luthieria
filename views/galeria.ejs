<!-- Hero Section -->
<section class="cta-section">
    <div class="container text-center">
        <h1 class="page-hero-title">Galeria de Trabalhos</h1>
        <p class="page-hero-subtitle">
            Veja alguns exemplos dos nossos trabalhos realizados. Cada projeto é único e recebe atenção especial aos detalhes.
        </p>
    </div>
</section>

<!-- Galeria Principal -->
<section class="section-padding bg-white">
    <div class="container">
        <div class="gallery-grid">
            <% trabalhos.forEach(function(trabalho) { %>
            <div class="gallery-item">
                <div class="gallery-card">
                    <h3 class="gallery-title"><%= trabalho.title %></h3>
                    <p class="gallery-description"><%= trabalho.description %></p>
                    
                    <div class="before-after-container">
                        <div class="before-after-item">
                            <h4>Antes</h4>
                            <img src="<%= trabalho.before %>" alt="<%= trabalho.title %> - Antes" class="gallery-image">
                        </div>
                        <div class="before-after-item">
                            <h4>Depois</h4>
                            <img src="<%= trabalho.after %>" alt="<%= trabalho.title %> - Depois" class="gallery-image">
                        </div>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</section>
                                <p class="text-sm">Baixo Fender 4 Cordas</p>
                                <button class="mt-4 bg-gold-600 hover:bg-gold-700 px-4 py-2 rounded-lg transition-colors" onclick="openLightbox('setup-baixo-fender')">
                                    Ver Detalhes
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Item 3 - Reparo -->
            <div class="gallery-item" data-category="reparo">
                <div class="group cursor-pointer">
                    <div class="relative overflow-hidden rounded-xl bg-gray-200 aspect-square">
                        <img src="/images/galeria/violao-reparo.jpg" alt="Reparo Violão" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" loading="lazy">
                        <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                            <div class="text-white text-center">
                                <h3 class="text-xl font-semibold mb-2">Reparo de Rachadura</h3>
                                <p class="text-sm">Violão Clássico</p>
                                <button class="mt-4 bg-gold-600 hover:bg-gold-700 px-4 py-2 rounded-lg transition-colors" onclick="openLightbox('reparo-violao-classico')">
                                    Ver Detalhes
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Item 4 - Customização -->
            <div class="gallery-item" data-category="customizacao">
                <div class="group cursor-pointer">
                    <div class="relative overflow-hidden rounded-xl bg-gray-200 aspect-square">
                        <img src="/images/galeria/guitarra-custom.jpg" alt="Customização Guitarra" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" loading="lazy">
                        <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                            <div class="text-white text-center">
                                <h3 class="text-xl font-semibold mb-2">Customização</h3>
                                <p class="text-sm">Guitarra Stratocaster</p>
                                <button class="mt-4 bg-gold-600 hover:bg-gold-700 px-4 py-2 rounded-lg transition-colors" onclick="openLightbox('custom-stratocaster')">
                                    Ver Detalhes
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Item 5 - Restauração -->
            <div class="gallery-item" data-category="restauracao">
                <div class="group cursor-pointer">
                    <div class="relative overflow-hidden rounded-xl bg-gray-200 aspect-square">
                        <img src="/images/galeria/banjo-restauracao.jpg" alt="Restauração Banjo" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" loading="lazy">
                        <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                            <div class="text-white text-center">
                                <h3 class="text-xl font-semibold mb-2">Restauração Banjo</h3>
                                <p class="text-sm">Banjo Vintage dos anos 50</p>
                                <button class="mt-4 bg-gold-600 hover:bg-gold-700 px-4 py-2 rounded-lg transition-colors" onclick="openLightbox('restauracao-banjo-vintage')">
                                    Ver Detalhes
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Item 6 - Setup -->
            <div class="gallery-item" data-category="setup">
                <div class="group cursor-pointer">
                    <div class="relative overflow-hidden rounded-xl bg-gray-200 aspect-square">
                        <img src="/images/galeria/violao-eletrico-setup.jpg" alt="Setup Violão Eletroacústico" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" loading="lazy">
                        <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                            <div class="text-white text-center">
                                <h3 class="text-xl font-semibold mb-2">Setup Completo</h3>
                                <p class="text-sm">Violão Eletroacústico</p>
                                <button class="mt-4 bg-gold-600 hover:bg-gold-700 px-4 py-2 rounded-lg transition-colors" onclick="openLightbox('setup-violao-eletrico')">
                                    Ver Detalhes
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Botão Carregar Mais -->
        <div class="text-center mt-12">
            <button id="load-more" class="bg-primary-800 hover:bg-primary-900 text-white font-semibold px-8 py-4 rounded-lg transition-colors duration-300">
                Carregar Mais Trabalhos
            </button>
        </div>
    </div>
</section>

<!-- Seção Antes/Depois -->
<section class="py-20 bg-primary-50">
    <div class="container mx-auto px-4">
        <div class="text-center mb-16">
            <h2 class="text-4xl font-serif font-bold text-primary-800 mb-4">Antes e Depois</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">
                Veja a transformação completa de alguns dos nossos trabalhos mais marcantes
            </p>
        </div>
        
        <div class="space-y-16">
            <% trabalhos.forEach((trabalho, index) => { %>
            <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
                <div class="grid lg:grid-cols-2">
                    <!-- Antes -->
                    <div class="relative">
                        <img src="<%= trabalho.antes %>" alt="<%= trabalho.titulo %> - Antes" class="w-full h-64 lg:h-80 object-cover">
                        <div class="absolute top-4 left-4 bg-red-600 text-white px-4 py-2 rounded-lg font-semibold">
                            ANTES
                        </div>
                    </div>
                    <!-- Depois -->
                    <div class="relative">
                        <img src="<%= trabalho.depois %>" alt="<%= trabalho.titulo %> - Depois" class="w-full h-64 lg:h-80 object-cover">
                        <div class="absolute top-4 left-4 bg-green-600 text-white px-4 py-2 rounded-lg font-semibold">
                            DEPOIS
                        </div>
                    </div>
                </div>
                <div class="p-8">
                    <h3 class="text-2xl font-serif font-bold text-primary-800 mb-4"><%= trabalho.titulo %></h3>
                    <p class="text-gray-600 text-lg"><%= trabalho.descricao %></p>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Vídeos -->
<section class="py-20 bg-white">
    <div class="container mx-auto px-4">
        <div class="text-center mb-16">
            <h2 class="text-4xl font-serif font-bold text-primary-800 mb-4">Vídeos dos Trabalhos</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">
                Acompanhe o processo de alguns dos nossos trabalhos através destes vídeos
            </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Vídeo 1 -->
            <div class="bg-gray-100 rounded-xl overflow-hidden shadow-lg">
                <div class="relative aspect-video bg-gray-200">
                    <video 
                        class="w-full h-full object-cover" 
                        poster="/images/video-thumb-1.jpg"
                        controls
                        preload="metadata"
                        loading="lazy">
                        <source src="/videos/trabalho-guitarra.mp4" type="video/mp4">
                        Seu navegador não suporta vídeos HTML5.
                    </video>
                </div>
                <div class="p-6">
                    <h3 class="text-lg font-semibold text-primary-800 mb-2">Restauração Guitarra Les Paul</h3>
                    <p class="text-gray-600 text-sm">Processo completo de restauração de uma Les Paul dos anos 70</p>
                </div>
            </div>
            
            <!-- Vídeo 2 -->
            <div class="bg-gray-100 rounded-xl overflow-hidden shadow-lg">
                <div class="relative aspect-video bg-gray-200">
                    <video 
                        class="w-full h-full object-cover" 
                        poster="/images/video-thumb-2.jpg"
                        controls
                        preload="metadata"
                        loading="lazy">
                        <source src="/videos/setup-baixo.mp4" type="video/mp4">
                        Seu navegador não suporta vídeos HTML5.
                    </video>
                </div>
                <div class="p-6">
                    <h3 class="text-lg font-semibold text-primary-800 mb-2">Setup Completo em Baixo</h3>
                    <p class="text-gray-600 text-sm">Demonstração do processo de setup profissional</p>
                </div>
            </div>
            
            <!-- Vídeo 3 -->
            <div class="bg-gray-100 rounded-xl overflow-hidden shadow-lg">
                <div class="relative aspect-video bg-gray-200">
                    <video 
                        class="w-full h-full object-cover" 
                        poster="/images/video-thumb-3.jpg"
                        controls
                        preload="metadata"
                        loading="lazy">
                        <source src="/videos/troca-trastes.mp4" type="video/mp4">
                        Seu navegador não suporta vídeos HTML5.
                    </video>
                </div>
                <div class="p-6">
                    <h3 class="text-lg font-semibold text-primary-800 mb-2">Troca de Trastes</h3>
                    <p class="text-gray-600 text-sm">Técnica especializada para troca de trastes</p>
                </div>
            </div>
        </div>
    </div>
</section>

