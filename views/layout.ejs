<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= description %>">
    <meta name="keywords" content="luthieria, instrumentos musicais, manutenção, reparos, guitarra, violão, baixo, setup">
    <meta name="author" content="Prime Luthieria">
    
    <!-- Open Graph -->
    <meta property="og:title" content="<%= title %>">
    <meta property="og:description" content="<%= description %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://primeluthieria.com">
    <meta property="og:image" content="/images/og-image.jpg">
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= title %>">
    <meta name="twitter:description" content="<%= description %>">
    <meta name="twitter:image" content="/images/twitter-card.jpg">
    
    <title><%= title %></title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css?v=1.0">
    
    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Prime Luthieria",
        "description": "Especialistas em manutenção e reparos de instrumentos musicais",
        "url": "https://primeluthieria.com",
        "telephone": "+55 11 99999-9999",
        "address": {
            "@type": "PostalAddress",
            "streetAddress": "Rua dos Músicos, 123",
            "addressLocality": "São Paulo",
            "addressRegion": "SP",
            "postalCode": "01234-567",
            "addressCountry": "BR"
        },
        "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.9",
            "reviewCount": "127"
        },
        "openingHours": "Mo-Fr 09:00-18:00, Sa 09:00-14:00"
    }
    </script>
    
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=GA_MEASUREMENT_ID"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'GA_MEASUREMENT_ID');
    </script>
</head>
<body>
    <!-- Header -->
    <header>
        <nav>
            <div class="nav-brand">
                <div class="logo-placeholder">🎸</div>
                <div class="brand-text">
                    <h1 class="logo"><%= typeof siteData !== 'undefined' ? siteData.site.name : 'Prime Luthieria' %></h1>
                    <p class="tagline"><%= typeof siteData !== 'undefined' ? siteData.site.tagline : 'Especialistas em Instrumentos Musicais' %></p>
                </div>
            </div>
            
            <!-- Desktop Menu -->
            <ul class="nav-links">
                <li><a href="/" class="nav-link <%= currentPage === 'home' ? 'active' : '' %>">Início</a></li>
                <li><a href="/sobre" class="nav-link <%= currentPage === 'sobre' ? 'active' : '' %>">Sobre</a></li>
                <li><a href="/servicos" class="nav-link <%= currentPage === 'servicos' ? 'active' : '' %>">Serviços</a></li>
                <li><a href="/galeria" class="nav-link <%= currentPage === 'galeria' ? 'active' : '' %>">Galeria</a></li>
                <li><a href="/contato" class="nav-link <%= currentPage === 'contato' ? 'active' : '' %>">Contato</a></li>
            </ul>
            
            <!-- Mobile Menu Button -->
            <button id="mobile-menu-btn" class="mobile-menu-btn">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </nav>
        
        <!-- Mobile Menu -->
        <div id="mobile-menu" class="mobile-menu">
            <a href="/" class="mobile-link">Início</a>
            <a href="/sobre" class="mobile-link">Sobre</a>
            <a href="/servicos" class="mobile-link">Serviços</a>
            <a href="/galeria" class="mobile-link">Galeria</a>
            <a href="/contato" class="mobile-link">Contato</a>
        </div>
    </header>
                </ul>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <main class="pt-20">
        <%- body %>
    </main>

    <!-- Footer -->
    <footer>
        <div class="footer-content">
            <div class="footer-grid">
                <!-- Informações da Empresa -->
                <div class="footer-section footer-brand">
                    <div class="footer-logo">
                        <img src="/images/logo-white.png" alt="Prime Luthieria" class="footer-logo-img">
                        <div>
                            <h3>Prime Luthieria</h3>
                            <p class="footer-tagline">Tradição e Qualidade</p>
                        </div>
                    </div>
                    <p class="footer-description">
                        Especialistas em manutenção e reparos de instrumentos musicais há mais de 10 anos. 
                        Cuidamos do seu instrumento com o carinho e técnica que ele merece.
                    </p>
                    <div class="social-links">
                        <a href="<%= typeof siteData !== 'undefined' ? siteData.site.social_media.instagram : '#' %>" class="social-link" target="_blank">
                            <svg class="social-icon" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                            </svg>
                        </a>
                        <a href="<%= typeof siteData !== 'undefined' ? siteData.site.social_media.facebook : '#' %>" class="social-link" target="_blank">
                            <svg class="social-icon" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                            </svg>
                        </a>
                        <a href="<%= typeof siteData !== 'undefined' ? siteData.site.social_media.youtube : '#' %>" class="social-link" target="_blank">
                            <svg class="social-icon" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                            </svg>
                        </a>
                        <a href="<%= typeof siteData !== 'undefined' ? siteData.site.social_media.twitter : '#' %>" class="social-link" target="_blank">
                            <svg class="social-icon" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                            </svg>
                        </a>
                    </div>
                </div>
                
                <!-- Links Rápidos -->
                <div>
                    <h4 class="footer-title">Links Rápidos</h4>
                    <ul class="footer-links">
                        <li><a href="/" class="footer-link">Início</a></li>
                        <li><a href="/sobre" class="footer-link">Sobre Nós</a></li>
                        <li><a href="/servicos" class="footer-link">Serviços</a></li>
                        <li><a href="/galeria" class="footer-link">Galeria</a></li>
                        <li><a href="/contato" class="footer-link">Contato</a></li>
                    </ul>
                </div>
                
                <!-- Contato -->
                <div>
                    <h4 class="footer-title">Contato</h4>
                    <div class="footer-contact">
                        <div class="contact-item">
                            <svg class="contact-icon" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
                                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
                            </svg>
                            <span class="contact-text"><%= typeof siteData !== 'undefined' ? siteData.site.email : 'contato@primeluthieria.com' %></span>
                        </div>
                        <div class="contact-item">
                            <svg class="contact-icon" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"></path>
                            </svg>
                            <span class="contact-text">(<%= typeof siteData !== 'undefined' ? siteData.site.phone.substring(0,2) : '11' %>) <%= typeof siteData !== 'undefined' ? siteData.site.phone.substring(2,7) : '99999' %>-<%= typeof siteData !== 'undefined' ? siteData.site.phone.substring(7) : '9999' %></span>
                        </div>
                        <div class="contact-item">
                            <svg class="contact-icon" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
                            </svg>
                            <span class="contact-text">
                                <% if (typeof siteData !== 'undefined') { %>
                                    <%= siteData.site.address.street %><br>
                                    <%= siteData.site.address.neighborhood %>, <%= siteData.site.address.city %> - <%= siteData.site.address.state %><br>
                                    <%= siteData.site.address.zipcode %>
                                <% } else { %>
                                    Rua dos Músicos, 123<br>São Paulo - SP<br>01234-567
                                <% } %>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Avaliações -->
            <div class="mt-12 pt-8 border-t border-primary-700">
                <h4 class="text-lg font-semibold mb-6 text-center">O que nossos clientes dizem</h4>
                <div id="testimonials" class="max-w-4xl mx-auto">
                    <!-- Os depoimentos serão inseridos aqui via JavaScript -->
                </div>
            </div>
            
            <!-- Copyright -->
            <div class="mt-8 pt-8 border-t border-primary-700 text-center">
                <p class="text-primary-300">
                    © 2025 Prime Luthieria. Todos os direitos reservados.
                </p>
            </div>
        </div>
    </footer>

    <!-- JavaScript -->
    <script src="/js/main.js"></script>
    
    <!-- Google reCAPTCHA (apenas na página de contato) -->
    <% if (currentPage === 'contato') { %>
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    <% } %>
</body>
</html>
