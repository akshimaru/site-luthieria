<!-- Hero Section -->
<section class="cta-section">
    <div class="container text-center">
        <h1 class="page-hero-title">Nossos Serviços</h1>
        <p class="page-hero-subtitle">
            Oferecemos uma gama completa de serviços especializados em luthieria para todos os tipos de instrumentos de corda
        </p>
    </div>
</section>

<!-- Lista de Serviços -->
<section class="section-padding bg-white">
    <div class="container">
        <div class="services-list-grid">
            <% servicos.forEach((servico, index) => { %>
            <div class="service-detailed-card">
                <div class="service-detailed-layout">
                    <div class="service-image-container">
                        <img src="<%= servico.imagem %>" alt="<%= servico.nome %>" class="service-detailed-image">
                    </div>
                    <div class="service-detailed-content">
                        <h3 class="service-detailed-title"><%= servico.nome %></h3>
                        <p class="service-detailed-description"><%= servico.descricao %></p>
                        <div class="service-detailed-footer">
                            <span class="service-detailed-price"><%= servico.preco %></span>
                            <a href="/contato" class="btn btn-primary">
                                Solicitar Orçamento
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Processo de Trabalho -->
<section class="section-padding bg-primary-light">
    <div class="container">
        <div class="text-center mb-16">
            <h2 class="section-title">Nosso Processo</h2>
            <p class="section-subtitle">
                Seguimos um processo rigoroso para garantir a máxima qualidade em todos os nossos serviços
            </p>
        </div>
        
        <div class="process-grid">
            <!-- Passo 1 -->
            <div class="process-step">
                <div class="process-number">
                    1
                </div>
                <h3 class="process-title">Avaliação</h3>
                <p class="process-description">
                    Análise detalhada do instrumento, identificação de problemas e definição do escopo do trabalho.
                </p>
            </div>
            
            <!-- Passo 2 -->
            <div class="process-step">
                <div class="process-number">
                    2
                </div>
                <h3 class="process-title">Orçamento</h3>
                <p class="process-description">
                    Elaboração de orçamento detalhado com explicação dos serviços necessários e prazo de execução.
                </p>
            </div>
            
            <!-- Passo 3 -->
            <div class="process-step">
                <div class="process-number">
                    3
                </div>
                <h3 class="process-title">Execução</h3>
                <p class="process-description">
                    Realização dos serviços com técnicas especializadas e documentação fotográfica do processo.
                </p>
            </div>
            
            <!-- Passo 4 -->
            <div class="process-step">
                <div class="process-number">
                    4
                </div>
                <h3 class="process-title">Entrega</h3>
                <p class="process-description">
                    Teste final, ajustes finais e entrega do instrumento com garantia dos serviços realizados.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Instrumentos Atendidos -->
<section class="section-padding bg-white">
    <div class="container">
        <div class="text-center mb-16">
            <h2 class="section-title">Instrumentos Atendidos</h2>
            <p class="section-subtitle">
                Trabalhamos com todos os tipos de instrumentos de corda, elétricos e acústicos
            </p>
        </div>
        
        <div class="instruments-grid">
            <!-- Guitarras Elétricas -->
            <div class="instrument-card">
                <div class="mission-icon">
                    <svg class="icon-lg" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z"></path>
                    </svg>
                </div>
                <h3 class="instrument-title">Guitarras Elétricas</h3>
                <p class="instrument-description">Stratocaster, Les Paul, Telecaster, SG e todos os modelos</p>
            </div>
            
            <!-- Violões -->
            <div class="instrument-card">
                <div class="mission-icon">
                    <svg class="icon-lg" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z"></path>
                    </svg>
                </div>
                <h3 class="instrument-title">Violões</h3>
                <p class="instrument-description">Acústicos, clássicos, folk, 12 cordas e eletroacústicos</p>
            </div>
            
            <!-- Baixos -->
            <div class="instrument-card">
                <div class="mission-icon">
                    <svg class="icon-lg" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z"></path>
                    </svg>
                </div>
                <h3 class="instrument-title">Baixos</h3>
                <p class="instrument-description">4, 5 e 6 cordas, fretless, semi-acústicos</p>
            </div>
            
            <!-- Banjos -->
            <div class="instrument-card">
                <div class="mission-icon">
                    <svg class="icon-lg" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z"></path>
                    </svg>
                </div>
                <h3 class="instrument-title">Banjos</h3>
                <p class="instrument-description">Tradicionais, elétricos e híbridos</p>
            </div>
            
            <!-- Mandolins -->
            <div class="instrument-card">
                <div class="mission-icon">
                    <svg class="icon-lg" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z"></path>
                    </svg>
                </div>
                <h3 class="instrument-title">Mandolins</h3>
                <p class="instrument-description">Flat top, carved top, elétricos</p>
            </div>
            
            <!-- Ukuleles -->
            <div class="instrument-card">
                <div class="mission-icon">
                    <svg class="icon-lg" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z"></path>
                    </svg>
                </div>
                <h3 class="instrument-title">Ukuleles</h3>
                <p class="instrument-description">Soprano, concert, tenor, baritone</p>
            </div>
        </div>
    </div>
</section>

<!-- Garantia -->
<section class="section-padding bg-primary-light">
    <div class="container">
        <div class="guarantee-container">
            <h2 class="section-title text-center">Garantia e Qualidade</h2>
            <p class="section-subtitle text-center">
                Todos os nossos serviços possuem garantia e são realizados com os mais altos padrões de qualidade
            </p>
            
            <div class="guarantee-grid">
                <div class="guarantee-card">
                    <div class="mission-icon">
                        <svg class="icon-lg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <h3 class="guarantee-title">90 Dias de Garantia</h3>
                    <p class="guarantee-description">
                        Todos os serviços possuem garantia de 90 dias contra defeitos de execução.
                    </p>
                </div>
                
                <div class="guarantee-card">
                    <div class="mission-icon">
                        <svg class="icon-lg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                        </svg>
                    </div>
                    <h3 class="guarantee-title">Segurança Total</h3>
                    <p class="guarantee-description">
                        Seu instrumento fica seguro em nosso workshop com sistema de monitoramento 24h.
                    </p>
                </div>
                
                <div class="guarantee-card">
                    <div class="mission-icon">
                        <svg class="icon-lg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                        </svg>
                    </div>
                    <h3 class="guarantee-title">Satisfação Garantida</h3>
                    <p class="guarantee-description">
                        Seu instrumento só sai daqui quando você estiver 100% satisfeito com o resultado.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="cta-section">
    <div class="container text-center">
        <h2 class="cta-title">
            Pronto para Cuidar do Seu Instrumento?
        </h2>
        <p class="cta-subtitle">
            Entre em contato conosco e solicite um orçamento personalizado. 
            Nossos especialistas estão prontos para atender você.
        </p>
        <div class="cta-buttons">
            <a href="/contato" class="btn btn-primary">
                Solicitar Orçamento
            </a>
            <a href="tel:+5511999999999" class="btn btn-outline">
                (11) 99999-9999
            </a>
        </div>
    </div>
</section>
