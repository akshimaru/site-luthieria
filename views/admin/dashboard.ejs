<div class="dashboard">
    <div class="dashboard-welcome">
        <h2>Bem-vindo ao Painel Administrativo!</h2>
        <p>Aqui você pode gerenciar todas as informações do site Prime Luthieria.</p>
    </div>
    
    <div class="dashboard-grid">
        <div class="dashboard-card">
            <h3>Informações Gerais</h3>
            <p>Gerencie dados básicos do site como nome, descrição, contato e endereço.</p>
            <a href="/admin/site-info" class="btn btn-primary">Gerenciar</a>
        </div>
        
        <div class="dashboard-card">
            <h3>Página Hero</h3>
            <p>Edite o conteúdo da seção principal da página inicial.</p>
            <a href="/admin/hero" class="btn btn-primary">Gerenciar</a>
        </div>
        
        <div class="dashboard-card">
            <h3>Página Sobre</h3>
            <p>Atualize informações sobre a empresa, missão, visão e valores.</p>
            <a href="/admin/about" class="btn btn-primary">Gerenciar</a>
        </div>
        
        <div class="dashboard-card">
            <h3>Equipe</h3>
            <p>Adicione, edite ou remova membros da equipe.</p>
            <a href="/admin/team" class="btn btn-primary">Gerenciar</a>
        </div>
        
        <div class="dashboard-card">
            <h3>Serviços</h3>
            <p>Gerencie os serviços oferecidos, preços e descrições.</p>
            <a href="/admin/services" class="btn btn-primary">Gerenciar</a>
        </div>
        
        <div class="dashboard-card">
            <h3>Galeria</h3>
            <p>Adicione e organize fotos dos trabalhos realizados.</p>
            <a href="/admin/gallery" class="btn btn-primary">Em breve</a>
        </div>
    </div>
    
    <div class="dashboard-info">
        <h3>Informações do Sistema</h3>
        <div class="info-grid">
            <div class="info-item">
                <strong>Nome do Site:</strong> <%= siteData.site.name %>
            </div>
            <div class="info-item">
                <strong>Telefone:</strong> <%= siteData.site.phone %>
            </div>
            <div class="info-item">
                <strong>Email:</strong> <%= siteData.site.email %>
            </div>
            <div class="info-item">
                <strong>Total de Serviços:</strong> <%= siteData.services.length %>
            </div>
            <div class="info-item">
                <strong>Membros da Equipe:</strong> <%= siteData.about.team.length %>
            </div>
        </div>
    </div>
</div>
