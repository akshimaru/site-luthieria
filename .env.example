# Variáveis de Ambiente - Prime Luthieria

# Porta do servidor (EasyPanel geralmente usa 3000)
PORT=3000

# Ambiente (production para EasyPanel)
NODE_ENV=production

# Configurações de Email (Opcional)
EMAIL_USER=contato@primeluthieria.com
EMAIL_PASS=sua_senha_aqui
EMAIL_CONTACT=contato@primeluthieria.com

# Google reCAPTCHA (Opcional)
RECAPTCHA_SITE_KEY=6LcXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RECAPTCHA_SECRET_KEY=6LcXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Google Analytics (Opcional)
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Session Secret (Recomendado para produção)
SESSION_SECRET=sua_chave_secreta_aleatoria_aqui

# URL base do site
BASE_URL=https://primeluthieria.com

# Configurações de Sessão
SESSION_SECRET=seu_secret_super_seguro_aqui

# Configurações de Cache
CACHE_DURATION=3600
