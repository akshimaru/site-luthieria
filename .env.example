# ===============================================
# CONFIGURAÇÃO PARA PRODUÇÃO VPS/EASYPANEL
# ===============================================

# AMBIENTE (OBRIGATÓRIO)
NODE_ENV=production

# PORTA (OBRIGATÓRIO - NÃO ALTERAR)
PORT=3000

# SEGURANÇA (OBRIGATÓRIO - ALTERE PARA UMA CHAVE ÚNICA)
SESSION_SECRET=prime_luthieria_production_secret_key_123456789

# CONFIGURAÇÕES DE SEGURANÇA (RECOMENDADO)
TRUST_PROXY=true
SECURE_COOKIES=true

# CONFIGURAÇÕES DE EMAIL (OPCIONAL)
EMAIL_USER=contato@seudominio.com
EMAIL_PASS=sua_senha_de_app_email
EMAIL_FROM=Prime Luthieria <contato@seudominio.com>
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# GOOGLE ANALYTICS (OPCIONAL)
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# GOOGLE RECAPTCHA (OPCIONAL)
RECAPTCHA_SITE_KEY=6LcXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RECAPTCHA_SECRET_KEY=6LcXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# CONFIGURAÇÕES DE DOMÍNIO (OPCIONAL)
DOMAIN=https://seudominio.com
BASE_URL=https://seudominio.com

# URL base do site
BASE_URL=https://primeluthieria.com

# Configurações de Sessão
